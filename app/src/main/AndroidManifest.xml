<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AlzheimerObregon">
        <activity
            android:name=".main.MainActivity"
            android:exported="true"
            android:label="Main" />
        <activity
            android:name=".features.patient.ui.PatientsActivity"
            android:exported="true"
            android:label="Pacientes" />
        <activity
            android:name=".features.patient.ui.PatientDetailActivity"
            android:exported="true"
            android:label="Detalle paciente" />
        <activity
            android:name=".features.auth.ui.LoginActivity"
            android:exported="true"
            android:label="Login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".features.patient.ui.PatientRegisterActivity"
            android:exported="true"
            android:label="Registrar paciente" />
        <activity
            android:name=".features.evaluation.ui.EvaluationHistoryActivity"
            android:exported="true"
            android:label="Historial de evaluaciones" />
        <activity
            android:name=".features.evaluation.ui.InstrumentsActivity"
            android:exported="true"
            android:label="Seleccionar instrumento" />
    </application>

</manifest>